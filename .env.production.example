APP_NAME="IDI_V_BANYU__"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://idi-v-banyu.com.ua

APP_LOCALE=uk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uk_UA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# sync — заявка летить у Telegram одразу, без воркера (шаред-хостинг)
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@idi-v-banyu.com.ua"
MAIL_FROM_NAME="${APP_NAME}"

# --- Telegram (заявки з форми замовлення) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Контакти ---
SUPPORT_PHONE=380974772919

# --- Адмін Filament (створюється сидером: php artisan db:seed) ---
ADMIN_NAME="Адміністратор"
ADMIN_EMAIL=admin@idi-v-banyu.zmova.com.ua
ADMIN_PASSWORD=

# --- SEO: код підтвердження Google Search Console (метод «HTML-тег») ---
GOOGLE_SITE_VERIFICATION=
